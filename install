#!/bin/bash
set -e

# Packages to install
PACKAGES=(cmake gcc go ninja neovim fzf fd gh ripgrep rustup lazygit lld llvm uv)

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

log_info() { echo "[INFO] $*"; }
log_success() { echo "[OK]   $*"; }

# Set up Claude Code config
mkdir -p "$HOME/.claude"
ln -sf "$SCRIPT_DIR/claude/CLAUDE.md" "$HOME/.claude/CLAUDE.md"
ln -sf "$SCRIPT_DIR/claude/settings.json" "$HOME/.claude/settings.json"
log_success "Claude Code config symlinked."

# Set up shell config
ln -sf "$SCRIPT_DIR/shell/bashrc" "$HOME/.bashrc"
ln -sf "$SCRIPT_DIR/shell/bash_aliases" "$HOME/.bash_aliases"
log_success "Shell config symlinked."

# Set up essential git configuration
log_info "Configuring git..."
git config --global user.name "Peter Cheng"
git config --global user.email "7921604+pcheng17@users.noreply.github.com"
git config --global core.editor "nvim"
git config --global init.defaultBranch "main"
git config --global pull.rebase "false"
git config --global rebase.updaterefs "true"
git config --global --replace-all credential.https://github.com.helper "!$(brew --prefix)/bin/gh auth git-credential"
log_success "Git configured."

# Install Homebrew if not already installed
if ! command -v brew &>/dev/null; then
    log_info "Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
else
    log_success "Homebrew already installed, skipping."
fi

# Ensure brew is in PATH
eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"

INSTALLED_PACKAGES=$(brew list --formula 2>/dev/null)
TO_INSTALL=()
for pkg in "${PACKAGES[@]}"; do
    if echo "$INSTALLED_PACKAGES" | grep -q "^${pkg}$"; then
        log_success "$pkg already installed, skipping."
    else
        log_info "Queuing $pkg for installation..."
        TO_INSTALL+=("$pkg")
    fi
done

if [[ ${#TO_INSTALL[@]} -gt 0 ]]; then
    log_info "Installing packages: ${TO_INSTALL[*]}"
    brew install "${TO_INSTALL[@]}"
fi

# Install Python 3.14 via uv
if uv python find 3.14 &>/dev/null; then
    log_success "Python 3.14 already installed via uv, skipping."
else
    log_info "Installing Python 3.14 via uv..."
    uv python install 3.14
    log_success "Python 3.14 installed."
fi

# Install nvm and Node.js 22
if [[ ! -d "$HOME/.nvm" ]]; then
    log_info "Installing nvm..."
    curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.3/install.sh | bash
else
    log_success "nvm already installed, skipping."
fi

export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && source "$NVM_DIR/nvm.sh"

if ! nvm ls 22 &>/dev/null; then
    log_info "Installing Node.js 22..."
    nvm install 22
    nvm alias default 22
else
    log_success "Node.js 22 already installed, skipping."
fi

# Install Claude Code if not already installed
if ! command -v claude &>/dev/null; then
    log_info "Installing Claude Code..."
    curl -fsSL https://claude.ai/install.sh | bash
else
    log_success "Claude Code already installed, skipping."
fi

# Install Docker Engine if not already installed
if ! command -v docker &>/dev/null; then
    log_info "Installing Docker Engine..."
    curl -fsSL https://get.docker.com | sh
    sudo usermod -aG docker "$USER"
    log_info "Docker installed. You may need to log out and back in for group changes to take effect."
else
    log_success "Docker already installed, skipping."
fi

# Install qhull from pcheng17/qhull
if command -v qhull &>/dev/null; then
    log_success "qhull already installed, skipping."
else
    log_info "Installing qhull from source..."
    QHULL_TMP=$(mktemp -d)
    git clone --depth 1 --branch master --recurse-submodules https://github.com/pcheng17/qhull "$QHULL_TMP/qhull"
    cmake -S "$QHULL_TMP/qhull" -B "$QHULL_TMP/qhull/build" -G Ninja \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_C_COMPILER=clang \
        -DCMAKE_CXX_COMPILER=clang++ \
        -DCMAKE_INSTALL_PREFIX=/usr/local
    ninja -C "$QHULL_TMP/qhull/build" install -j4
    rm -rf "$QHULL_TMP"
    log_success "qhull installed."
fi

log_success "Done!"
